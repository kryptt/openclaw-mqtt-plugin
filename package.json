{
  "name": "@kryptt/openclaw-mqtt-plugin",
  "version": "0.2.4",
  "description": "OpenClaw plugin: bridge agent bus messages to/from MQTT for cross-agent coordination",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryptt/openclaw-mqtt-plugin.git"
  },
  "dependencies": {
    "effect": "^3.14.0",
    "mqtt": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.5"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.5"
    },
    "build": {
      "openclawVersion": "2026.4.5"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
